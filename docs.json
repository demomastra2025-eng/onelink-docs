    },
    "body": {
      "family": "Haskoy",
      "weight": 400,
      "source": "https://d1j5ayohogpcd2.cloudfront.net/fonts/haskoy/Haskoy-Regular.woff2",
      "format": "woff2"
    }
  },
  "theme": "maple",
