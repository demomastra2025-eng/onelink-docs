{
  "$schema": "https://mintlify.com/docs.json",
  "name": "OneLink",
  "description": "Product, platform, API, and domain documentation for the OneLink platform.",
  "logo": {
    "dark": "/logo/icon.svg",
    "light": "/logo/icon.svg"
  },
  "favicon": "/favicon.ico",
  "colors": {
    "primary": "#111111",
    "light": "#2F2F2F",
    "dark": "#000000"
  },
  "fonts": {
    "heading": {
      "family": "Haskoy",
      "weight": 500,
      "source": "https://d1j5ayohogpcd2.cloudfront.net/fonts/haskoy/Haskoy-Medium.woff2",
      "format": "woff2"
    },
    "body": {
      "family": "Haskoy",
      "weight": 400,
      "source": "https://d1j5ayohogpcd2.cloudfront.net/fonts/haskoy/Haskoy-Regular.woff2",
      "format": "woff2"
    }
  },
  "theme": "maple",
  "seo": {
    "metatags": {
      "canonical": "https://docs.one-link.kz"
    }
  },
  "navigation": {
    "anchors": [
      {
        "anchor": "Introduction",
        "icon": "house",
        "pages": ["introduction"]
      },
      {
        "anchor": "Platform",
        "icon": "sitemap",
        "pages": [
          {
            "group": "Current State",
            "pages": [
              "platform/overview",
              "platform/current-architecture",
              "platform/repository-map",
              "platform/frontend-implementation",
              "platform/integrations-architecture"
            ]
          },
          {
            "group": "Direction And Decisions",
            "pages": [
              "contributing-guide/domain-access-architecture",
              "platform/crm-architecture",
              "platform/entity-matrix",
              "platform/decision-matrix",
              "platform/implementation-roadmap"
            ]
          }
        ]
      },
      {
        "anchor": "Domains",
        "pages": [
          {
            "group": "Profiles",
            "pages": [
              "domains/overview",
              "domains/generic-profile",
              "domains/healthcare-profile",
              "domains/construction-profile"
            ]
          }
        ]
      },
      {
        "anchor": "API Reference",
        "icon": "square-terminal",
        "pages": [],
        "groups": [
          {
            "group": "Getting Started",
            "description": "Learn about the API surfaces exposed by the OneLink platform",
            "pages": ["api-reference/introduction"]
          },
          {
            "group": "Application APIs",
            "description": "APIs for managing account-level and agent-facing product behavior",
            "includeTags": [
              "Agents",
              "Automation Rule",
              "Account AgentBots",
              "Canned Responses",
              "Contact Labels",
              "Contacts",
              "Conversation Assignments",
              "Conversation Labels",
              "Conversations",
              "Custom Attributes",
              "Custom Filters",
              "Help Center",
              "Inboxes",
              "Integrations",
              "Messages",
              "Profile",
              "Reports",
              "Teams",
              "Webhooks"
            ],
            "openapi": "openapi/application_swagger.json"
          },
          {
            "group": "Platform APIs",
            "description": "APIs for installation and platform administration",
            "includeTags": ["Accounts", "Account Users", "AgentBots", "Users"],
            "openapi": "openapi/platform_swagger.json"
          },
          {
            "group": "Client APIs",
            "description": "APIs for client-facing chat applications",
            "includeTags": [
              "Contacts API",
              "Conversations API",
              "Messages API"
            ],
            "openapi": "openapi/client_swagger.json"
          },
          {
            "group": "Other APIs",
            "description": "Additional APIs used by the forked product surface",
            "includeTags": ["CSAT Survey Page"],
            "openapi": "openapi/other_swagger.json"
          }
        ]
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/demomastra2025-eng/onelink-docs"
    }
  }
}
